OE_MCP_BASE_URL=https://www.openevidence.com
# OE_MCP_ROOT_DIR=/absolute/path/.openevidence-mcp
# OE_MCP_COOKIES_PATH=/absolute/path/openevidence-mcp/cookies.json
# OE_MCP_AUTH_STATE_PATH is still accepted as a legacy alias for OE_MCP_COOKIES_PATH.
# OE_MCP_ARTIFACT_DIR=/tmp/openevidence-mcp
# OE_MCP_CROSSREF_MAILTO=you@example.com
# OE_MCP_CROSSREF_VALIDATE=1

# Polling controls for oe_ask when wait_for_completion=true
OE_MCP_POLL_INTERVAL_MS=1200
OE_MCP_POLL_TIMEOUT_MS=180000
